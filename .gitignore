# Gitignore for rbx-infra

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Secrets (never commit actual secrets)
*.secret.yml
*.secret.yaml
secrets/
.env
.env.*

# Temporary files
*.tmp
*.temp
tmp/
temp/

# Generated files
docs/structure.txt

# Ansible
*.retry
*.log
bootstrap/ansible/*.log
bootstrap/ansible/group_vars/vault.yml
bootstrap/ansible/group_vars/all/vault.yml

# K9s
*.log

# Kustomize build output
build/

# Terraform
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
# .terraform.lock.hcl is intentionally committed (pins provider versions)
.claude/
